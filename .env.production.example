COMPOSE_PROJECT_NAME=post_md_web
APP_PORT=8080

APP_NAME=post_md
APP_ENV=production
APP_DEBUG=false
APP_KEY=
APP_URL=https://post-md.example.com
APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=pt_BR
APP_TIMEZONE=UTC

PHP_VERSION=8.4.22
COMPOSER_VERSION=2.8
NGINX_IMAGE=nginx:1.30.2-alpine3.23
NODE_IMAGE=node:24-bookworm-slim
POSTGRES_IMAGE=postgres:18.4-alpine
REDIS_IMAGE=redis:8.6.4-alpine3.23

POSTGRES_DB=post_md
POSTGRES_USER=post_md
POSTGRES_PASSWORD=
REDIS_PASSWORD=

DB_CONNECTION=pgsql
DB_HOST=db
DB_PORT=5432
DB_DATABASE=post_md
DB_USERNAME=post_md
DB_PASSWORD=

CACHE_STORE=redis
SESSION_DRIVER=redis
QUEUE_CONNECTION=redis

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PORT=6379

LOG_CHANNEL=stderr
LOG_LEVEL=warning
FILESYSTEM_DISK=local

SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax
