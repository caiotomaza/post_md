# Docker Compose
COMPOSE_PROJECT_NAME=post_md
APP_PORT=8000
VITE_PORT=5173
APP_UID=1000
APP_GID=1000

# Versions
LARAVEL_VERSION=^13.0
PHP_VERSION=8.4.22
COMPOSER_VERSION=2.8
NGINX_IMAGE=nginx:1.30.2-alpine3.23
NODE_IMAGE=node:24-bookworm-slim
POSTGRES_IMAGE=postgres:18.4-alpine
REDIS_IMAGE=redis:8.6.4-alpine3.23

# PostgreSQL
POSTGRES_DB=post_md
POSTGRES_USER=post_md
POSTGRES_PASSWORD=change_me_postgres

# Redis
REDIS_PASSWORD=change_me_redis

# Development
XDEBUG_MODE=off
